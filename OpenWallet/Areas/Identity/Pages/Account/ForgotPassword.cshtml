@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
    var ar = Request.Cookies["openwallet-lang"] == "ar";
}

<section class="auth-shell">
    <article class="auth-card">
        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="chip-button" data-wallet-lang><i class="bi bi-translate"></i><span>@(ar ? "English" : "العربية")</span></button>
        </div>
        <h1 class="h3 fw-bold">@(ar ? "استعادة كلمة المرور" : "Forgot your password?")</h1>
        <p class="text-muted">@(ar ? "أدخل بريدك الإلكتروني المسجل وسنرسل لك رابطاً آمناً لإعادة تعيين كلمة المرور." : "Enter your registered email and we will send a secure link to reset your password.")</p>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <p class="small text-muted mb-2">@(ar ? "استخدم نفس البريد الإلكتروني المرتبط بحساب OpenWallet الخاص بك." : "Use the same email address linked to your OpenWallet account.")</p>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label"></label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">@(ar ? "إرسال رابط إعادة التعيين" : "Reset Password")</button>
            <a class="btn btn-outline-secondary w-100 mt-2" asp-page="./Login">@(ar ? "العودة إلى تسجيل الدخول" : "Back to login")</a>
        </form>
    </article>
    <article class="auth-hero">
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h2 class="display-6 fw-bold mt-5">@(ar ? "استعادة آمنة للحساب" : "Secure account recovery")</h2>
            <p class="lead">@(ar ? "سنساعدك على استعادة الوصول بدون كشف حالة الحساب أو تفاصيله." : "We help you recover access without exposing account status or sensitive details.")</p>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
