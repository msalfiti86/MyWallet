@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = L["ForgotPasswordTitle"];
}

<section class="auth-shell">
    <article class="auth-card">
        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="chip-button" data-wallet-lang><i class="bi bi-translate"></i><span>@L["LanguageSwitch"]</span></button>
        </div>
        <h1 class="h3 fw-bold">@L["ForgotPasswordTitle"]</h1>
        <p class="text-muted">@L["ForgotPasswordDescription"]</p>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <p class="small text-muted mb-2">@L["ForgotPasswordEmailHelp"]</p>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">@L["EmailAddress"]</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">@L["SendResetLink"]</button>
            <a class="btn btn-outline-secondary w-100 mt-2" asp-page="./Login">@L["BackToLogin"]</a>
        </form>
    </article>
    <article class="auth-hero">
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h2 class="display-6 fw-bold mt-5">@L["SecureAccountRecovery"]</h2>
            <p class="lead">@L["SecureAccountRecoveryDescription"]</p>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
