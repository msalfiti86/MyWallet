@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
}

<section class="auth-shell">
    <article class="auth-card">
        <form id="account" method="post">
            <h1 class="h3 fw-bold">Welcome back</h1>
            <p class="text-muted">Sign in to manage wallets, approvals, transactions, and compliance workflows.</p>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="admin@openwallet.local" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <label class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <span class="form-check-label">@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
            </label>
            <button id="login-submit" type="submit" class="btn btn-primary w-100 py-3">Continue securely</button>
            <div class="d-flex justify-content-between gap-3 mt-3 small">
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot password?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create organization</a>
            </div>
        </form>
    </article>
    <article class="auth-hero">
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h2 class="display-6 fw-bold mt-5">Two-factor fintech operations</h2>
            <p class="lead">Built for Arabic and English teams, Saudi wallet flows, audit-heavy approvals, and responsive administration.</p>
        </div>
        <div class="d-grid gap-3">
            <div class="d-flex justify-content-between"><span>Default admin</span><strong>admin@openwallet.local</strong></div>
            <div class="d-flex justify-content-between"><span>Seed password</span><strong>Admin@123456</strong></div>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
