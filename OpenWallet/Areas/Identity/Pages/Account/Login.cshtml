@page
@model LoginModel
@{
    ViewData["Title"] = L["LoginTitle"];
}

<section class="auth-shell">
    <article class="auth-card">
        <div class="d-flex justify-content-end mb-3">
            <button type="button" class="chip-button" data-wallet-lang><i class="bi bi-translate"></i><span>@L["LanguageSwitch"]</span></button>
        </div>
        <form id="account" method="post">
            <h1 class="h3 fw-bold">@L["WelcomeBack"]</h1>
            <p class="text-muted">@L["LoginDescription"]</p>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">@L["EmailAddress"]</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="admin@openwallet.local" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">@L["Password"]</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="@L["EnterPassword"]" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <label class="form-check mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <span class="form-check-label">@L["RememberMe"]</span>
            </label>
            <button id="login-submit" type="submit" class="btn btn-primary w-100 py-3">@L["ContinueSecurely"]</button>
            <div class="d-flex justify-content-between gap-3 mt-3 small">
                <a id="forgot-password" asp-page="./ForgotPassword">@L["ForgotPasswordQuestion"]</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">@L["CreateOrganization"]</a>
            </div>
        </form>
    </article>
    <article class="auth-hero">
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h2 class="display-6 fw-bold mt-5">@L["TwoFactorFintechOperations"]</h2>
            <p class="lead">@L["LoginHeroDescription"]</p>
        </div>
        <div class="d-grid gap-3">
            <div class="d-flex justify-content-between"><span>@L["DefaultAdmin"]</span><strong>admin@openwallet.local</strong></div>
            <div class="d-flex justify-content-between"><span>@L["SeedPassword"]</span><strong>Admin@123456</strong></div>
        </div>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
