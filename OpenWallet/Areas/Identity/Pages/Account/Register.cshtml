@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<section class="auth-shell">
    <article class="auth-hero">
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h1 class="display-5 fw-bold mt-5">Create an organization wallet workspace</h1>
            <p class="lead mt-3">Register the organization and manager together, then continue into KYC, wallet setup, OTP-protected transfers, and permission-based operations.</p>
        </div>
        <div class="wizard-steps"><span></span><span></span><span></span></div>
    </article>
    <article class="auth-card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2 class="h4 fw-bold">Organization registration</h2>
            <p class="text-muted">No user can be created without an organization.</p>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="row g-3">
                <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationLegalNameEn"></label><input asp-for="Input.OrganizationLegalNameEn" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationLegalNameAr"></label><input asp-for="Input.OrganizationLegalNameAr" class="form-control" dir="rtl" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationShortName"></label><input asp-for="Input.OrganizationShortName" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.CommercialRegistrationNumber"></label><input asp-for="Input.CommercialRegistrationNumber" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.FirstNameEn"></label><input asp-for="Input.FirstNameEn" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.LastNameEn"></label><input asp-for="Input.LastNameEn" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.Email"></label><input asp-for="Input.Email" class="form-control" autocomplete="username" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.MobileNumber"></label><input asp-for="Input.MobileNumber" class="form-control" placeholder="+9665XXXXXXXX" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.NationalIdOrIqama"></label><input asp-for="Input.NationalIdOrIqama" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.DateOfBirthGregorian"></label><input asp-for="Input.DateOfBirthGregorian" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.City"></label><input asp-for="Input.City" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.PostalCode"></label><input asp-for="Input.PostalCode" class="form-control" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.Password"></label><input asp-for="Input.Password" class="form-control" autocomplete="new-password" /></div>
                <div class="col-md-6"><label class="form-label" asp-for="Input.ConfirmPassword"></label><input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" /></div>
            </div>
            <button id="registerSubmit" type="submit" class="btn btn-primary w-100 mt-4 py-3">Create organization and manager</button>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
