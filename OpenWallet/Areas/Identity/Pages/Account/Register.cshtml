@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    var ar = Request.Cookies["openwallet-lang"] == "ar";
}

<section class="auth-shell register-shell">
    <article class="auth-hero">
        <div class="d-flex justify-content-end">
            <button type="button" class="chip-button" data-wallet-lang><i class="bi bi-translate"></i><span>@(ar ? "English" : "العربية")</span></button>
        </div>
        <div>
            <span class="brand-mark"><span class="brand-icon"><i class="bi bi-wallet2"></i></span><span><strong>OpenWallet</strong><small>KSA</small></span></span>
            <h1 class="display-5 fw-bold mt-5">@(ar ? "إنشاء مساحة محافظ للمؤسسة" : "Create an organization wallet workspace")</h1>
            <p class="lead mt-3">@(ar ? "تسجيل موجه لبيانات المؤسسة وهوية المدير وأمان المحفظة والموافقة على السياسات." : "A guided registration for organization details, manager identity, wallet security, and policy agreement.")</p>
        </div>
        <div class="wizard-steps" data-register-progress><span class="active"></span><span></span><span></span></div>
    </article>
    <article class="auth-card register-card">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" novalidate>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 fw-bold mb-1">@(ar ? "تسجيل المؤسسة" : "Organization registration")</h2>
                    <p class="text-muted mb-0">@(ar ? "لا يمكن إنشاء مستخدم بدون مؤسسة." : "No user can be created without an organization.")</p>
                </div>
                <span class="status-badge status-active" data-step-label>@(ar ? "الخطوة 1 من 3" : "Step 1 of 3")</span>
            </div>
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="register-step is-active" data-step="1">
                <h3 class="h6 fw-bold mb-3">@(ar ? "معلومات المؤسسة" : "Organization information")</h3>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationLegalNameEn"></label><input asp-for="Input.OrganizationLegalNameEn" class="form-control" maxlength="120" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationLegalNameAr"></label><input asp-for="Input.OrganizationLegalNameAr" class="form-control" maxlength="120" dir="rtl" /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.OrganizationShortName"></label><input asp-for="Input.OrganizationShortName" class="form-control" maxlength="40" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.CommercialRegistrationNumber"></label><input asp-for="Input.CommercialRegistrationNumber" class="form-control" maxlength="10" pattern="\d{10}" required placeholder="10 digits" /></div>
                </div>
            </div>

            <div class="register-step" data-step="2">
                <h3 class="h6 fw-bold mb-3">@(ar ? "معلومات المدير" : "Manager information")</h3>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label" asp-for="Input.FirstNameEn"></label><input asp-for="Input.FirstNameEn" class="form-control" maxlength="60" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.LastNameEn"></label><input asp-for="Input.LastNameEn" class="form-control" maxlength="60" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.Email"></label><input asp-for="Input.Email" class="form-control" autocomplete="username" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.MobileNumber"></label><input asp-for="Input.MobileNumber" class="form-control" maxlength="13" placeholder="+9665XXXXXXXX" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.NationalIdOrIqama"></label><input asp-for="Input.NationalIdOrIqama" class="form-control" maxlength="10" pattern="[12]\d{9}" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.IdType"></label><select asp-for="Input.IdType" asp-items="Model.IdTypes" class="form-select"></select></div>
                    <div class="col-md-4"><label class="form-label" asp-for="Input.DateOfBirthGregorian"></label><input asp-for="Input.DateOfBirthGregorian" class="form-control" required /></div>
                    <div class="col-md-4"><label class="form-label" asp-for="Input.City"></label><input asp-for="Input.City" class="form-control" maxlength="80" required /></div>
                    <div class="col-md-4"><label class="form-label" asp-for="Input.PostalCode"></label><input asp-for="Input.PostalCode" class="form-control" maxlength="5" pattern="\d{5}" required /></div>
                </div>
            </div>

            <div class="register-step" data-step="3">
                <h3 class="h6 fw-bold mb-3">@(ar ? "الأمان والاتفاقية" : "Security and agreement")</h3>
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label" asp-for="Input.Password"></label><input asp-for="Input.Password" class="form-control" autocomplete="new-password" required /></div>
                    <div class="col-md-6"><label class="form-label" asp-for="Input.ConfirmPassword"></label><input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" required /></div>
                    <div class="col-12">
                        <label class="form-check agreement-box">
                            <input class="form-check-input" asp-for="Input.AcceptTerms" required />
                            <span class="form-check-label">
                                @(ar ? "أوافق على" : "I accept the OpenWallet KSA")
                                <a asp-page="/Legal/Terms" target="_blank">@(ar ? "الشروط وسياسة الخصوصية واتفاقية المحفظة" : "terms, privacy policy, and wallet agreement")</a>
                                @(ar ? "وأوافق على تسجيل التدقيق للعمليات الحساسة." : "and consent to audit logging for sensitive actions.")
                            </span>
                        </label>
                        <span asp-validation-for="Input.AcceptTerms" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <a class="btn btn-outline-secondary flex-fill" asp-page="./Login">@(ar ? "إلغاء" : "Cancel")</a>
                <button class="btn btn-outline-secondary flex-fill" type="button" data-register-prev disabled>@(ar ? "رجوع" : "Back")</button>
                <button class="btn btn-primary flex-fill" type="button" data-register-next>@(ar ? "التالي" : "Next")</button>
                <button id="registerSubmit" type="submit" class="btn btn-primary flex-fill d-none">@(ar ? "إنشاء المؤسسة والمدير" : "Create organization and manager")</button>
            </div>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            let step = 1;
            const steps = [...document.querySelectorAll(".register-step")];
            const progress = [...document.querySelectorAll("[data-register-progress] span")];
            const prev = document.querySelector("[data-register-prev]");
            const next = document.querySelector("[data-register-next]");
            const submit = document.getElementById("registerSubmit");
            const label = document.querySelector("[data-step-label]");
            const show = () => {
                steps.forEach(s => s.classList.toggle("is-active", Number(s.dataset.step) === step));
                progress.forEach((p, i) => p.classList.toggle("active", i < step));
                prev.disabled = step === 1;
                next.classList.toggle("d-none", step === 3);
                submit.classList.toggle("d-none", step !== 3);
                label.textContent = document.documentElement.lang === "ar" ? `الخطوة ${step} من 3` : `Step ${step} of 3`;
            };
            const validCurrent = () => {
                const current = document.querySelector(`.register-step[data-step="${step}"]`);
                return [...current.querySelectorAll("input,select")].every(i => i.reportValidity());
            };
            next.addEventListener("click", () => { if (validCurrent() && step < 3) { step += 1; show(); } });
            prev.addEventListener("click", () => { if (step > 1) { step -= 1; show(); } });
            show();
        })();
    </script>
}
