@page "{id:guid?}"
@model OpenWallet.Pages.Beneficiaries.EditModel
@{
    ViewData["Title"] = Model.Ar ? "مستفيد" : "Beneficiary";
}

<section class="page-header">
    <div>
        <h1>@(Model.Ar ? "بيانات المستفيد" : "Beneficiary details")</h1>
        <p>@(Model.Ar ? "عند الحفظ سيظهر رمز التحقق لتأكيد العملية." : "When you save, an OTP popup will confirm the action.")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="Index">@(Model.Ar ? "رجوع" : "Back")</a>
</section>

<form method="post" class="panel-card" data-requires-otp="true" data-otp-purpose="Beneficiary.Save" data-otp-send-url="@Url.Page(null, "SendOtp")">
    <input asp-for="Input.Id" type="hidden" />
    <input asp-for="Input.OtpCode" type="hidden" data-otp-hidden />
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label" asp-for="Input.BeneficiaryType">@(Model.Ar ? "نوع المستفيد" : "Beneficiary type")</label>
            <select class="form-select" asp-for="Input.BeneficiaryType" asp-items="Model.Types"></select>
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="Input.Nickname">@(Model.Ar ? "الاسم المختصر" : "Nickname")</label>
            <input class="form-control" asp-for="Input.Nickname" />
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.FullNameEn">@(Model.Ar ? "الاسم بالإنجليزية" : "English full name")</label>
            <input class="form-control" asp-for="Input.FullNameEn" />
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.FullNameAr">@(Model.Ar ? "الاسم بالعربية" : "Arabic full name")</label>
            <input class="form-control" asp-for="Input.FullNameAr" dir="rtl" />
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="Input.MobileNumber">@(Model.Ar ? "رقم الجوال" : "Mobile number")</label>
            <input class="form-control" asp-for="Input.MobileNumber" />
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="Input.Email">@(Model.Ar ? "البريد الإلكتروني" : "Email")</label>
            <input class="form-control" asp-for="Input.Email" />
        </div>
        <div class="col-md-4">
            <label class="form-label" asp-for="Input.WalletNumber">@(Model.Ar ? "رقم المحفظة" : "Wallet number")</label>
            <input class="form-control" asp-for="Input.WalletNumber" />
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.BankName">@(Model.Ar ? "اسم البنك" : "Bank name")</label>
            <input class="form-control" asp-for="Input.BankName" />
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.Iban">@(Model.Ar ? "IBAN" : "IBAN")</label>
            <input class="form-control" asp-for="Input.Iban" />
        </div>
    </div>
    <span class="text-danger" asp-validation-for="Input.OtpCode"></span>
    <button class="btn btn-primary mt-4">@(Model.Ar ? "حفظ" : "Save")</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
