@page
@{ ViewData["Title"] = "Complaints"; }
<section class="page-header"><div><h1>Complaints</h1><p>Customer support cases linked to users, organizations, and wallet transactions.</p></div><button class="btn btn-primary"><i class="bi bi-chat-left-text"></i> New complaint</button></section>
<section class="table-card"><div class="table-responsive"><table class="data-table"><thead><tr><th>Title</th><th>Category</th><th>Priority</th><th>Status</th><th>Assigned</th><th>Updated</th></tr></thead><tbody><tr><td>Transfer delay</td><td>TransferIssue</td><td>High</td><td><span class="status-badge status-pending">InProgress</span></td><td>SupportAgent</td><td>Today</td></tr></tbody></table></div></section>
