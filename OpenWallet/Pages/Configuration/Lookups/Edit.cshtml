@page "{id:guid?}"
@model OpenWallet.Pages.Configuration.Lookups.EditModel
@{
    ViewData["Title"] = "Lookup";
}

<section class="page-header">
    <div>
        <h1>@Model.T("Lookup")</h1>
        <p>@Model.T("LookupEditText")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="Index">@Model.T("Back")</a>
</section>

<form method="post" class="panel-card">
    <input asp-for="Input.Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.Name"></label>
            <input class="form-control" asp-for="Input.Name" />
            <span class="text-danger" asp-validation-for="Input.Name"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="Input.Description"></label>
            <input class="form-control" asp-for="Input.Description" />
        </div>
        <div class="col-12">
            <label class="form-check">
                <input class="form-check-input" asp-for="Input.IsActive" />
                <span class="form-check-label">@Model.T("Active")</span>
            </label>
        </div>
    </div>

    <hr />
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 m-0">@Model.T("LookupDetails")</h2>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-add-detail><i class="bi bi-plus"></i> @Model.T("AddRow")</button>
    </div>
    <div id="detailRows" class="d-grid gap-2">
        @for (var i = 0; i < Model.Input.Details.Count; i++)
        {
            <div class="row g-2 lookup-row">
                <input asp-for="Input.Details[i].Id" type="hidden" />
                <div class="col-md-2"><input class="form-control" asp-for="Input.Details[i].Code" placeholder="@Model.T("Code")" /></div>
                <div class="col-md-4"><input class="form-control" asp-for="Input.Details[i].ValueEn" placeholder="@Model.T("ValueEn")" /></div>
                <div class="col-md-4"><input class="form-control" asp-for="Input.Details[i].ValueAr" placeholder="@Model.T("ValueAr")" dir="rtl" /></div>
                <div class="col-md-1"><input class="form-control" asp-for="Input.Details[i].SortOrder" /></div>
                <div class="col-md-1 d-flex align-items-center"><input class="form-check-input" asp-for="Input.Details[i].IsActive" /></div>
            </div>
        }
    </div>
    <button class="btn btn-primary mt-4" type="submit">@Model.T("Save")</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector("[data-add-detail]")?.addEventListener("click", () => {
            const rows = document.getElementById("detailRows");
            const i = rows.querySelectorAll(".lookup-row").length;
            rows.insertAdjacentHTML("beforeend", `<div class="row g-2 lookup-row">
                <input name="Input.Details[${i}].Id" type="hidden" value="00000000-0000-0000-0000-000000000000" />
                <div class="col-md-2"><input class="form-control" name="Input.Details[${i}].Code" placeholder="Code" /></div>
                <div class="col-md-4"><input class="form-control" name="Input.Details[${i}].ValueEn" placeholder="Value EN" /></div>
                <div class="col-md-4"><input class="form-control" name="Input.Details[${i}].ValueAr" placeholder="Value AR" dir="rtl" /></div>
                <div class="col-md-1"><input class="form-control" name="Input.Details[${i}].SortOrder" value="${i + 1}" /></div>
                <div class="col-md-1 d-flex align-items-center"><input class="form-check-input" type="checkbox" name="Input.Details[${i}].IsActive" value="true" checked /></div>
            </div>`);
        });
    </script>
}
