@page
@model OpenWallet.Pages.Configuration.Lookups.IndexModel
@{
    ViewData["Title"] = L["Lookups"];
}

<section class="page-header">
    <div>
        <h1>@L["Lookups"]</h1>
        <p>@L["ManageLookupText"]</p>
    </div>
    <a class="btn btn-primary" asp-page="Edit"><i class="bi bi-plus-circle"></i> @L["NewLookup"]</a>
</section>

<section class="table-card">
    <div class="table-responsive">
        <table class="data-table">
            <thead><tr><th>@L["LookupName"]</th><th>@L["Details"]</th><th>@L["Status"]</th><th>@L["Actions"]</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Lookups)
            {
                <tr>
                    <td><strong>@item.Name</strong><br /><small class="text-muted">@item.Description</small></td>
                    <td>@item.Details.Count</td>
                    <td><span class="status-badge @(item.IsActive ? "status-active" : "status-failed")">@(item.IsActive ? L["Active"] : L["Inactive"])</span></td>
                    <td class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-secondary" asp-page="Edit" asp-route-id="@item.Id">@L["Edit"]</a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id">
                            <button class="btn btn-sm btn-outline-danger" type="submit">@L["Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
