@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-header">
    <div>
        <h1>Wallet command center</h1>
        <p>Monitor organization balance, approvals, suspicious activity, and user wallet operations from one responsive bilingual workspace.</p>
    </div>
    <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#otpModal"><i class="bi bi-plus-circle"></i> New transfer</button>
</section>

<section class="dashboard-grid">
    <article class="wallet-card">
        <span>Available balance</span>
        <div class="balance" data-counter>SAR 84250</div>
        <div class="wallet-number">OWKSA20260425123456</div>
        <div class="quick-actions">
            <button type="button" data-bs-toggle="modal" data-bs-target="#otpModal"><i class="bi bi-credit-card"></i> Top up</button>
            <button type="button" data-bs-toggle="modal" data-bs-target="#otpModal"><i class="bi bi-send"></i> Transfer</button>
            <button type="button"><i class="bi bi-file-earmark-arrow-down"></i> Statement</button>
        </div>
    </article>
    <article class="panel-card">
        <h2 class="h5">Approval queue</h2>
        <p class="text-muted">High-value transfer awaiting FinanceManager review.</p>
        <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-3">
            <span>Supplier payout</span>
            <strong>SAR 7,413.80</strong>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary flex-fill">Approve</button>
            <button class="btn btn-outline-danger flex-fill" data-bs-toggle="modal" data-bs-target="#confirmModal">Reject</button>
        </div>
    </article>
</section>

<section class="stats-grid">
    <partial name="_PremiumStatCard" model='("Total In", "SAR 50000", "bi-arrow-down-circle", "success")' />
    <partial name="_PremiumStatCard" model='("Total Out", "SAR 8663", "bi-arrow-up-circle", "warning")' />
    <partial name="_PremiumStatCard" model='("Pending", "3", "bi-hourglass-split", "info")' />
    <partial name="_PremiumStatCard" model='("Suspicious", "1", "bi-shield-exclamation", "danger")' />
</section>

<section class="dashboard-grid">
    <article class="panel-card chart-wrap">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 m-0">Monthly spending</h2>
            <span class="status-badge status-active">Live</span>
        </div>
        <canvas id="monthlySpendingChart"></canvas>
    </article>
    <article class="panel-card">
        <h2 class="h5">Compliance signals</h2>
        <div class="d-grid gap-3 mt-3">
            <div class="d-flex justify-content-between"><span>KYC verified</span><strong>92%</strong></div>
            <div class="d-flex justify-content-between"><span>Suspended orgs</span><strong>2</strong></div>
            <div class="d-flex justify-content-between"><span>Failed logins today</span><strong>7</strong></div>
            <div class="d-flex justify-content-between"><span>Webhook failures</span><strong>1</strong></div>
        </div>
    </article>
</section>

<section class="table-card mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 m-0">Recent transactions</h2>
        <a asp-page="/Transactions/Index" class="btn btn-sm btn-outline-secondary">View all</a>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead><tr><th>Transaction</th><th>Type</th><th>Category</th><th>Total</th><th>Status</th><th>Risk</th></tr></thead>
            <tbody>
                <tr><td>TXN-20260425-090000-101</td><td>TopUp</td><td>TopUp</td><td>SAR 50,000.00</td><td><partial name="_TransactionStatusBadge" model='"Completed"' /></td><td>Normal</td></tr>
                <tr><td>TXN-20260425-101500-202</td><td>External transfer</td><td>SupplierPayment</td><td>SAR 7,413.80</td><td><partial name="_TransactionStatusBadge" model='"Pending"' /></td><td>Approval</td></tr>
                <tr><td>TXN-20260425-121500-303</td><td>Internal transfer</td><td>Business</td><td>SAR 1,250.00</td><td><partial name="_TransactionStatusBadge" model='"Completed"' /></td><td>Normal</td></tr>
            </tbody>
        </table>
    </div>
</section>
