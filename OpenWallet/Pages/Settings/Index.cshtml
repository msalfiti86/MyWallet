@page
@{ ViewData["Title"] = "Settings"; }
<section class="page-header"><div><h1>Settings</h1><p>Configure fees, limits, payments, security, localization, notification channels, and theme defaults.</p></div><button class="btn btn-primary"><i class="bi bi-save"></i> Save changes</button></section>
<section class="dashboard-grid"><article class="panel-card"><h2 class="h5">Fees</h2><div class="row g-3 mt-1"><div class="col-md-6"><label class="form-label">Internal transfer fixed</label><input class="form-control" value="0.00" /></div><div class="col-md-6"><label class="form-label">VAT percentage</label><input class="form-control" value="15" /></div><div class="col-md-6"><label class="form-label">External transfer fixed</label><input class="form-control" value="12.00" /></div><div class="col-md-6"><label class="form-label">High value threshold</label><input class="form-control" value="10000" /></div></div></article><article class="panel-card"><h2 class="h5">Localization and theme</h2><label class="form-label mt-3">Default language</label><select class="form-select"><option>en-US</option><option>ar-SA</option></select><label class="form-label mt-3">Default theme</label><select class="form-select"><option>System</option><option>Light</option><option>Dark</option></select></article></section>
