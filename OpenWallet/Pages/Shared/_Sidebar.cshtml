@{
    var ar = Context.Request.Cookies["openwallet-lang"] == "ar";
}
<aside class="wallet-sidebar" id="walletSidebar">
    <a class="brand-mark" asp-page="/Index" aria-label="OpenWallet KSA">
        <span class="brand-icon"><i class="bi bi-wallet2"></i></span>
        <span>
            <strong>OpenWallet</strong>
            <small>KSA</small>
        </span>
    </a>
    <nav class="sidebar-nav">
        <a asp-page="/Index"><i class="bi bi-grid-1x2-fill"></i><span>@(ar ? "لوحة التحكم" : "Dashboard")</span></a>
        <a asp-page="/Organizations/Index"><i class="bi bi-buildings"></i><span>@(ar ? "المنظمات" : "Organizations")</span></a>
        <a asp-page="/Users/Index"><i class="bi bi-people"></i><span>@(ar ? "المستخدمون" : "Users")</span></a>
        <a asp-page="/Wallets/Index"><i class="bi bi-wallet"></i><span>@(ar ? "المحافظ" : "Wallets")</span></a>
        <a asp-page="/Topup/Index"><i class="bi bi-credit-card"></i><span>@(ar ? "شحن المحفظة" : "Top up")</span></a>
        <a asp-page="/Transfer/Index"><i class="bi bi-send"></i><span>@(ar ? "تحويل" : "Transfer")</span></a>
        <a asp-page="/Transactions/Index"><i class="bi bi-arrow-left-right"></i><span>@(ar ? "الحركات" : "Transactions")</span></a>
        <a asp-page="/Statement/Index"><i class="bi bi-file-earmark-text"></i><span>@(ar ? "كشف الحساب" : "Statement")</span></a>
        <a asp-page="/Beneficiaries/Index"><i class="bi bi-person-vcard"></i><span>@(ar ? "المستفيدون" : "Beneficiaries")</span></a>
        <a asp-page="/Compliance/ReviewQueue"><i class="bi bi-shield-check"></i><span>@(ar ? "الامتثال" : "Compliance")</span></a>
        <a asp-page="/Complaints/Index"><i class="bi bi-chat-left-text"></i><span>@(ar ? "الشكاوى" : "Complaints")</span></a>
        <a asp-page="/Settings/Index"><i class="bi bi-sliders"></i><span>@(ar ? "الإعدادات" : "Settings")</span></a>
        <a asp-page="/Configuration/Lookups/Index"><i class="bi bi-list-columns-reverse"></i><span>@(ar ? "التهيئة - القوائم" : "Configuration - Lookups")</span></a>
        <a asp-page="/Configuration/VirtualAccounts/Index"><i class="bi bi-bank"></i><span>@(ar ? "التهيئة - الحسابات" : "Configuration - Virtual Accounts")</span></a>
    </nav>
    <div class="sidebar-card">
        <span class="pulse-dot"></span>
        <strong>@(ar ? "النظام يعمل" : "System healthy")</strong>
        <small>@(ar ? "المدفوعات التجريبية مفعلة" : "Mock payments enabled")</small>
    </div>
</aside>
