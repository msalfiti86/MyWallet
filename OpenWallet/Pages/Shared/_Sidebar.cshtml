<aside class="wallet-sidebar" id="walletSidebar">
    <a class="brand-mark" asp-page="/Index" aria-label="OpenWallet KSA">
        <span class="brand-icon"><i class="bi bi-wallet2"></i></span>
        <span>
            <strong>OpenWallet</strong>
            <small>KSA</small>
        </span>
    </a>
    <nav class="sidebar-nav">
        <a asp-page="/Index"><i class="bi bi-grid-1x2-fill"></i><span>@L["Dashboard"]</span></a>
        <a asp-page="/Organizations/Index"><i class="bi bi-buildings"></i><span>@L["Organizations"]</span></a>
        <a asp-page="/Users/Index"><i class="bi bi-people"></i><span>@L["Users"]</span></a>
        <a asp-page="/Wallets/Index"><i class="bi bi-wallet"></i><span>@L["Wallets"]</span></a>
        <a asp-page="/Topup/Index"><i class="bi bi-credit-card"></i><span>@L["TopUp"]</span></a>
        <a asp-page="/Transfer/Index"><i class="bi bi-send"></i><span>@L["Transfer"]</span></a>
        <a asp-page="/Transactions/Index"><i class="bi bi-arrow-left-right"></i><span>@L["Transactions"]</span></a>
        <a asp-page="/Statement/Index"><i class="bi bi-file-earmark-text"></i><span>@L["Statement"]</span></a>
        <a asp-page="/Beneficiaries/Index"><i class="bi bi-person-vcard"></i><span>@L["Beneficiaries"]</span></a>
        <a asp-page="/Compliance/ReviewQueue"><i class="bi bi-shield-check"></i><span>@L["Compliance"]</span></a>
        <a asp-page="/Complaints/Index"><i class="bi bi-chat-left-text"></i><span>@L["Complaints"]</span></a>
        <a asp-page="/Settings/Index"><i class="bi bi-sliders"></i><span>@L["Settings"]</span></a>
        <a asp-page="/Configuration/Lookups/Index"><i class="bi bi-list-columns-reverse"></i><span>@L["ConfigurationLookups"]</span></a>
        <a asp-page="/Configuration/VirtualAccounts/Index"><i class="bi bi-bank"></i><span>@L["ConfigurationVirtualAccounts"]</span></a>
    </nav>
    <div class="sidebar-card">
        <span class="pulse-dot"></span>
        <strong>@L["SystemHealthy"]</strong>
        <small>@L["MockPaymentsEnabled"]</small>
    </div>
</aside>
