<header class="wallet-topbar">
    <button class="icon-button d-lg-none" type="button" data-wallet-sidebar><i class="bi bi-list"></i></button>
    <div class="topbar-title">
        <span>OpenWallet Main Organization</span>
        <strong>SAR 84,250.00</strong>
    </div>
    <div class="topbar-actions">
        <button class="chip-button" type="button" data-wallet-lang><i class="bi bi-translate"></i><span>EN / AR</span></button>
        <button class="icon-button" type="button" data-wallet-theme aria-label="Toggle dark mode"><i class="bi bi-moon-stars"></i></button>
        <button class="icon-button notification-button" type="button" aria-label="Notifications"><i class="bi bi-bell"></i><span></span></button>
        <div class="dropdown">
            <button class="profile-button" data-bs-toggle="dropdown" type="button">
                <span>OW</span>
                <strong>Admin</strong>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">Profile</a></li>
                <li><a class="dropdown-item" asp-page="/Settings/Index">Settings</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Login">Login</a></li>
            </ul>
        </div>
    </div>
</header>
