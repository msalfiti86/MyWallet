@page
@model OpenWallet.Pages.Topup.IndexModel
@{
    ViewData["Title"] = "Top up";
}

<section class="page-header">
    <div>
        <h1>Top up wallet</h1>
        <p>Choose a mock card, PayPal, or bank account transfer top-up method.</p>
    </div>
</section>

<section class="dashboard-grid">
    <article class="panel-card">
        <h2 class="h5">Instant mock top-up</h2>
        <form method="post" class="row g-3 mt-1">
            <div class="col-md-6">
                <label class="form-label" asp-for="Input.Amount"></label>
                <input class="form-control" asp-for="Input.Amount" min="1" step="0.01" />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Input.PaymentMethod"></label>
                <select class="form-select" asp-for="Input.PaymentMethod">
                    <option value="Card">Card</option>
                    <option value="PayPal">PayPal</option>
                </select>
            </div>
            <div class="col-12">
                <button class="btn btn-primary w-100 py-3">Simulate payment and credit wallet</button>
            </div>
        </form>
    </article>

    <article class="wallet-card">
        <span>Bank account transfer</span>
        <h2 class="mt-3">Transfer to this account to top up your wallet</h2>
        <div class="wallet-number mt-4">@Model.Wallet?.BankName</div>
        <div class="wallet-number">@Model.Wallet?.VirtualIban</div>
        <p class="mt-4 mb-0">Use your virtual IBAN above. Once the bank transfer is received, it can be reconciled and credited to your wallet.</p>
    </article>
</section>

<section class="table-card mt-4">
    <h2 class="h5">Wallet account</h2>
    <div class="row g-3 mt-1">
        <div class="col-md-4"><strong>Wallet number</strong><br />@Model.Wallet?.WalletNumber</div>
        <div class="col-md-4"><strong>Account number</strong><br />@Model.Wallet?.AccountNumber</div>
        <div class="col-md-4"><strong>Available balance</strong><br />SAR @Model.Wallet?.AvailableBalance.ToString("N2")</div>
    </div>
</section>
