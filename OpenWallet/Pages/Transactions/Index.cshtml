@page
@model OpenWallet.Pages.Transactions.IndexModel
@{
    ViewData["Title"] = "Transactions";
}
<section class="page-header">
    <div>
        <h1>Transactions</h1>
        <p>Review wallet credits, debits, fees, VAT, top-ups, and transfers.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn btn-outline-secondary"><i class="bi bi-download"></i> Export</button>
        <a class="btn btn-outline-primary" asp-page="/Transfer/Index"><i class="bi bi-send"></i> New transfer</a>
        <a class="btn btn-primary" asp-page="/Topup/Index"><i class="bi bi-plus-circle"></i> New top-up</a>
    </div>
</section>
<section class="stats-grid">
    <partial name="_PremiumStatCard" model='("Completed", Model.CompletedCount.ToString("N0"), "bi-check-circle", "success")' />
    <partial name="_PremiumStatCard" model='("Pending", Model.PendingCount.ToString("N0"), "bi-hourglass", "warning")' />
    <partial name="_PremiumStatCard" model='("Failed", Model.FailedCount.ToString("N0"), "bi-x-circle", "danger")' />
    <partial name="_PremiumStatCard" model='("Today Volume", $"SAR {Model.TodayVolume:N2}", "bi-cash-stack", "info")' />
</section>
<section class="table-card">
    <div class="row g-2 mb-3">
        <div class="col-md"><input class="form-control" placeholder="Transaction number" /></div>
        <div class="col-md"><select class="form-select"><option>All statuses</option><option>Completed</option><option>Pending</option><option>Failed</option></select></div>
        <div class="col-md"><select class="form-select"><option>All types</option><option>TopUp</option><option>InternalTransfer</option><option>ExternalBankTransfer</option><option>Fee</option><option>Adjustment</option></select></div>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Transaction Number</th>
                    <th>Reference</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Direction</th>
                    <th>Virtual IBAN</th>
                    <th>Amount</th>
                    <th>Fee</th>
                    <th>VAT</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Transactions)
                {
                    <tr>
                        <td>@item.TransactionNumber</td>
                        <td>@item.ReferenceNumber</td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@item.TransactionType</td>
                        <td>@item.Direction</td>
                        <td>@item.VirtualIban</td>
                        <td>SAR @item.Amount.ToString("N2")</td>
                        <td>SAR @item.FeeAmount.ToString("N2")</td>
                        <td>SAR @item.VatAmount.ToString("N2")</td>
                        <td>SAR @item.TotalAmount.ToString("N2")</td>
                        <td><partial name="_TransactionStatusBadge" model="item.Status" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
