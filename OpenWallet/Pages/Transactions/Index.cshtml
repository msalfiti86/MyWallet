@page
@{
    ViewData["Title"] = "Transactions";
}
<section class="page-header"><div><h1>Transactions</h1><p>Search, filter, approve, export, refund, reverse, and flag suspicious wallet transactions.</p></div><div class="d-flex gap-2"><button class="btn btn-outline-secondary"><i class="bi bi-download"></i> Export</button><button class="btn btn-primary"><i class="bi bi-plus-circle"></i> New top-up</button></div></section>
<section class="stats-grid"><partial name="_PremiumStatCard" model='("Completed", "18", "bi-check-circle", "success")' /><partial name="_PremiumStatCard" model='("Pending", "3", "bi-hourglass", "warning")' /><partial name="_PremiumStatCard" model='("Failed", "1", "bi-x-circle", "danger")' /><partial name="_PremiumStatCard" model='("Today Volume", "SAR 58664", "bi-cash-stack", "info")' /></section>
<section class="table-card"><div class="row g-2 mb-3"><div class="col-md"><input class="form-control" placeholder="Transaction number" /></div><div class="col-md"><select class="form-select"><option>All statuses</option><option>Completed</option><option>Pending</option><option>Failed</option></select></div><div class="col-md"><select class="form-select"><option>All types</option><option>TopUp</option><option>InternalTransfer</option><option>ExternalBankTransfer</option></select></div></div><div class="table-responsive"><table class="data-table"><thead><tr><th>Transaction Number</th><th>Date</th><th>Type</th><th>Direction</th><th>Total</th><th>Status</th><th>Suspicious</th><th>Actions</th></tr></thead><tbody>
<tr><td>TXN-20260425-090000-101</td><td>2026-04-25</td><td>TopUp</td><td>Credit</td><td>SAR 50,000</td><td><partial name="_TransactionStatusBadge" model='"Completed"' /></td><td>No</td><td><button class="btn btn-sm btn-outline-warning">Refund</button></td></tr>
<tr><td>TXN-20260425-101500-202</td><td>2026-04-25</td><td>ExternalBankTransfer</td><td>Debit</td><td>SAR 7,413.80</td><td><partial name="_TransactionStatusBadge" model='"Pending"' /></td><td>No</td><td><button class="btn btn-sm btn-outline-danger">Flag</button></td></tr>
</tbody></table></div></section>
