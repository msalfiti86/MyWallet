{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=OpenWallet;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Wallet": {
    "DefaultCurrency": "SAR",
    "MockPayments": true,
    "RequireOtpForTransfers": true,
    "RequireApprovalAboveAmount": 10000
  },
  "Security": {
    "RequireTwoFactor": true,
    "OtpExpiryMinutes": 5
  },
  "EmailSettings": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "SenderEmail": "no-reply@openwallet.local",
    "SenderName": "OpenWallet KSA",
    "EnableSsl": true
  },
  "Recaptcha": {
    "Enabled": false,
    "SiteKey": "",
    "SecretKey": ""
  },
  "Firebase": {
    "Enabled": false,
    "ServerKey": "",
    "ProjectId": ""
  },
  "PaymentGateways": {
    "Card": {
      "Enabled": false,
      "ApiKey": "",
      "Secret": ""
    },
    "PayPal": {
      "Enabled": false,
      "ClientId": "",
      "Secret": ""
    },
    "BankAccount": {
      "Enabled": false,
      "ApiKey": "",
      "Secret": ""
    }
  },
  "Localization": {
    "DefaultCulture": "en-US",
    "SupportedCultures": [ "en-US", "ar-SA" ]
  },
  "Theme": {
    "DefaultTheme": "light"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
